# PocketPDF 本地开发配置模板
# 复制此文件为 local.properties 并填入你的实际值
# local.properties 已在 .gitignore 中排除，不会提交到 Git

# ── 签名配置 ──────────────────────────────────
# 生成 keystore 命令：
#   keytool -genkey -v -keystore pocketpdf-release.keystore \
#     -alias pocketpdf -keyalg RSA -keysize 2048 -validity 10000
KEYSTORE_PATH=../pocketpdf-release.keystore
KEYSTORE_PASSWORD=你的密码
KEY_ALIAS=pocketpdf
KEY_PASSWORD=你的密码

# ── Sentry DSN ─────────────────────────────────
# 在 https://sentry.io 创建 Android 项目后获取 DSN
# 格式：https://xxx@xxx.ingest.sentry.io/xxx
# 不填则 Sentry 自动禁用（不报错）
# 读取优先级：Gradle -PSENTRY_DSN > 环境变量 SENTRY_DSN > 此文件
SENTRY_DSN=
