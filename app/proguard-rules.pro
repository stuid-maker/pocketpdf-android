# =============================================================================
# PocketPDF — ProGuard / R8 Keep Rules
# =============================================================================
# These rules protect PocketPDF from unwanted code stripping/obfuscation.
# They cover: Moshi, Retrofit, Room, Hilt, PdfBox, MediaPipe, DataStore,
# Kotlinx Coroutines, Compose, ViewBinding, and all app components.
# =============================================================================


# ── General: never strip Debug builds ──────────────────────────────────────
-assumenosideeffects class android.util.Log {
    public static boolean isLoggable(java.lang.String, int);
    public static int v(...);
    public static int d(...);
    public static int i(...);
}


# ═════════════════════════════════════════════════════════════════════════════
# MOSHI (@JsonClass) — KSP codegen, keep all adapters and classes
# ═════════════════════════════════════════════════════════════════════════════
-keep class com.squareup.moshi.** { *; }
-keep @interface com.squareup.moshi.JsonClass

# Keep all classes annotated with @JsonClass (Moshi codegen)
-keep @com.squareup.moshi.JsonClass class * { *; }
-keep class * extends com.squareup.moshi.JsonAdapter { *; }
-keep class * extends com.squareup.moshi.JsonAdapter.Factory { *; }

# Explicit keep for known Moshi-annotated DTOs (defensive)
-keep class com.asuka.pocketpdf.data.remote.dto.** { *; }

# Keep Moshi adapters generated by KSP
-keep class **JsonAdapter { *; }
-keep class **MoshiJsonAdapter { *; }
-keepnames class * {
    @com.squareup.moshi.JsonClass <fields>;
}


# ═════════════════════════════════════════════════════════════════════════════
# RETROFIT — interfaces and return types
# ═════════════════════════════════════════════════════════════════════════════
-keep,allowobfuscation,allowshrinking interface com.asuka.pocketpdf.data.remote.LlmApi
-keep,allowobfuscation,allowshrinking interface retrofit2.** { *; }
-keep class retrofit2.** { *; }
-keepclasseswithmembers class * {
    @retrofit2.http.* <methods>;
}
-keepclassmembers,allowobfuscation class * {
    @com.squareup.moshi.Json <fields>;
}
-dontwarn retrofit2.**
-keep class com.asuka.pocketpdf.data.remote.** { *; }


# ═════════════════════════════════════════════════════════════════════════════
# OKHTTP — networking internals
# ═════════════════════════════════════════════════════════════════════════════
-dontwarn okhttp3.**
-dontwarn okio.**
-keep class okhttp3.** { *; }
-keep interface okhttp3.** { *; }
-keep class okio.** { *; }


# ═════════════════════════════════════════════════════════════════════════════
# ROOM — entities, DAOs, database, type converters
# ═════════════════════════════════════════════════════════════════════════════
-keep class * extends androidx.room.RoomDatabase { *; }
-keep @interface androidx.room.Entity
-keep @interface androidx.room.Dao
-keep @interface androidx.room.Database
-keep @interface androidx.room.TypeConverter
-keep @interface androidx.room.ForeignKey
-keep @interface androidx.room.Index
-keep @interface androidx.room.PrimaryKey
-keep @interface androidx.room.ColumnInfo

# Keep all Room-annotated classes
-keep @androidx.room.Entity class * { *; }
-keep @androidx.room.Dao class * { *; }
-keep @androidx.room.Database class * { *; }

# Explicit keep for known Room entities, DAOs, and database
-keep class com.asuka.pocketpdf.data.local.entity.** { *; }
-keep class com.asuka.pocketpdf.data.local.dao.** { *; }
-keep class com.asuka.pocketpdf.data.local.AppDatabase { *; }
-keep class com.asuka.pocketpdf.data.local.converter.** { *; }

# Room-generated classes (impl, _Impl suffix)
-keep class * extends androidx.room.RoomDatabase { *; }
-keep class *._Impl { *; }

# Keep Room TypeConverters
-keep @androidx.room.TypeConverter class * { *; }
-keepclassmembers class * {
    @androidx.room.TypeConverter <methods>;
}


# ═════════════════════════════════════════════════════════════════════════════
# HILT / DAGGER — generated components, injected classes
# ═════════════════════════════════════════════════════════════════════════════
-keep class dagger.** { *; }
-keep class javax.inject.** { *; }
-keep class * extends dagger.hilt.android.internal.managers.ViewComponentManager$FragmentContextWrapper { *; }

# Hilt-generated components
-keep class * extends dagger.hilt.android.components.** { *; }
-keep class * extends dagger.hilt.components.** { *; }
-keep class * extends dagger.hilt.android.internal.builders.** { *; }
-keep class * extends dagger.hilt.internal.GeneratedComponent { *; }
-keep class * extends dagger.hilt.android.internal.managers.** { *; }

# Hilt-generated module classes (Hilt_* prefix, *_Factory, *_Module)
-keep class **Hilt_* { *; }
-keep class **Hilt* { *; }
-keep class * extends dagger.hilt.internal.GeneratedComponentManager { *; }
-keepclassmembers class * {
    @dagger.hilt.android.internal.lifecycle.HiltViewModelMap <fields>;
    @dagger.hilt.android.internal.lifecycle.HiltViewModelMap.KeySet <fields>;
}

# Hilt ViewModels
-keep @dagger.hilt.android.lifecycle.HiltViewModel class * { *; }
-keep class * extends androidx.lifecycle.ViewModel { *; }

# @AndroidEntryPoint classes (Activities)
-keep @dagger.hilt.android.AndroidEntryPoint class * { *; }
-keep @dagger.hilt.android.ActivityRetainedScoped class * { *; }
-keep @dagger.hilt.android.SingletonComponent class * { *; }
-keep @dagger.hilt.android.components.ActivityComponent class * { *; }

# Hilt @Module / @InstallIn classes
-keep @dagger.Module class * { *; }
-keep @dagger.Provides class * { *; }
-keep @dagger.Binds class * { *; }

# Explicit keep for known Hilt modules
-keep class com.asuka.pocketpdf.di.** { *; }

# Hilt Worker
-keep class * extends androidx.work.ListenableWorker { *; }
-keep class * extends androidx.work.Worker { *; }
-keep class com.asuka.pocketpdf.data.indexing.IndexWorker { *; }

# AssistedInject for Worker
-keep @dagger.assisted.AssistedInject class * { *; }
-keep @dagger.assisted.AssistedFactory class * { *; }
-keep class * extends dagger.assisted.** { *; }


# ═════════════════════════════════════════════════════════════════════════════
# PDFBOX-ANDROID — keep everything (notorious with ProGuard)
# ═════════════════════════════════════════════════════════════════════════════
-keep class org.apache.pdfbox.** { *; }
-keep class com.tom_roush.pdfbox.** { *; }
-keep class com.tom_roush.pdfbox.android.** { *; }
-keep class org.apache.fontbox.** { *; }
-keep class org.apache.commons.logging.** { *; }

# PdfBox uses reflection for text extraction, rendering, etc.
-keepclassmembers class * {
    @org.apache.pdfbox.pdmodel.common.PDDestinationOrAction <fields>;
    @org.apache.pdfbox.cos.COSName <fields>;
}
-dontwarn org.apache.pdfbox.**
-dontwarn com.tom_roush.pdfbox.**
-dontwarn org.apache.fontbox.**

# Keep BouncyCastle (PdfBox dependency)
-keep class org.bouncycastle.** { *; }
-dontwarn org.bouncycastle.**


