# ═════════════════════════════════════════════════════════════════════════════
# JETPACK LIFECYCLE / LIVE DATA / VIEWMODEL
# ═════════════════════════════════════════════════════════════════════════════
-keep class androidx.lifecycle.** { *; }
-dontwarn androidx.lifecycle.**


# ═════════════════════════════════════════════════════════════════════════════
# WORK MANAGER
# ═════════════════════════════════════════════════════════════════════════════
