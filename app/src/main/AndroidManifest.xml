<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 调用 PC 端 LM Studio（adb reverse 转发到 localhost:1234）需要 INTERNET 权限 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".PocketPdfApp"
        android:allowBackup="false"
        tools:replace="android:allowBackup"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PocketPDF">

        <!--
          W2 Day 4: 禁用默认 WorkManager initializer，改用 HiltWorkerFactory。
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- LibraryActivity is the launcher; diagnostics is available from Settings. -->
        <activity
            android:name=".ui.library.LibraryActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.reader.ReaderActivity"
            android:exported="false"
            android:label="@string/app_name" />

        <activity
            android:name=".ui.diagnostics.DiagnosticsActivity"
            android:exported="false"
            android:label="连接诊断" />

        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:label="设置" />

        <activity
            android:name=".ui.chat.ChatActivity"
            android:exported="false"
            android:label="文档问答" />
    </application>

</manifest>
