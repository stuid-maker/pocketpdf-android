<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 调用 PC 端 LM Studio（adb reverse 转发到 localhost:1234）需要 INTERNET 权限 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".PocketPdfApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PocketPDF">

        <!--
          W2 Day 4: 禁用默认 WorkManager initializer，改用 HiltWorkerFactory。
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!--
          Week 1 Day 3 起：LibraryActivity 接管 LAUNCHER。
          PingActivity 代码保留，未来 W3 接 LLM 桥接时复用其"按钮 → ViewModel → UseCase → UiState"
          模板；不再作为启动入口（无 intent-filter）。如需手动验证 LM Studio 可在 W3 加 debug 菜单。
        -->
        <activity
            android:name=".ui.library.LibraryActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.reader.ReaderActivity"
            android:exported="false"
            android:label="@string/app_name" />

        <activity
            android:name=".ui.ping.PingActivity"
            android:exported="false"
            android:label="@string/app_name" />
    </application>

</manifest>
