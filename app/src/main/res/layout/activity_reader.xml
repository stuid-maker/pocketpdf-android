<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/reader_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.reader.ReaderActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_reader"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationContentDescription="@string/reader_back"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/reader_title_loading"
        app:titleCentered="false" />

    <FrameLayout
        android:id="@+id/reader_surface"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#202124"
        app:layout_constraintBottom_toTopOf="@id/reader_controls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar_reader">

        <ImageView
            android:id="@+id/iv_reader_page"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/reader_page_content_description"
            android:scaleType="fitCenter"
            android:visibility="gone"
            tools:src="@drawable/ic_pdf_doc"
            tools:visibility="visible" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progress_reader_load"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/group_reader_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tv_reader_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="?attr/colorOnPrimary"
                tools:text="PDF file missing" />
        </LinearLayout>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/reader_controls"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:visibility="visible">

        <ImageButton
            android:id="@+id/btn_reader_previous"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/reader_previous_page"
            android:src="@drawable/ic_chevron_left"
            app:tint="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/tv_reader_page_indicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            tools:text="1 / 12" />

        <ImageButton
            android:id="@+id/btn_reader_next"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/reader_next_page"
            android:src="@drawable/ic_chevron_right"
            app:tint="?attr/colorOnSurface" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
