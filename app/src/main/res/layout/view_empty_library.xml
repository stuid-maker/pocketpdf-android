<?xml version="1.0" encoding="utf-8"?>
<!--
  空状态视图：居中显示图标 + 文案 + 副按钮。
  独立 layout 文件方便 include 进 activity_library.xml，也方便未来其他列表（聊天 / 历史）复用同款空态。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    tools:visibility="visible">

    <ImageView
        android:id="@+id/iv_empty_library_icon"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:alpha="0.4"
        android:contentDescription="@null"
        android:src="@drawable/ic_library_empty"
        app:tint="?android:attr/textColorSecondary" />

    <TextView
        android:id="@+id/tv_empty_library_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="@string/library_empty_title"
        android:textAppearance="?attr/textAppearanceTitleMedium" />

    <TextView
        android:id="@+id/tv_empty_library_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="@string/library_empty_subtitle"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?android:attr/textColorSecondary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_empty_library_import"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/library_empty_button" />

</LinearLayout>
